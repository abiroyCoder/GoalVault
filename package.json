{
  "name": "skillstake",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @skillstake/web",
    "build": "npm run build --workspace @skillstake/web",
    "test": "npm run test --workspace @skillstake/web",
    "lint": "npm run lint --workspace @skillstake/web",
    "typecheck": "npm run typecheck --workspace @skillstake/web",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.17.0",
    "concurrently": "^10.0.3",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
